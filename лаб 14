Задача 5. Топ-3 слов
text = "hello world hello python world hello code"

words = text.split()
freq = {}

for word in words:
    freq[word] = freq.get(word, 0) + 1

top3 = sorted(freq.items(), key=lambda x: x[1], reverse=True)[:3]

print(top3)

адача 6. Удалить дубликаты (с сохранением порядка)
arr = [1, 2, 2, 3, 1, 4]

seen = set()
result = []

for num in arr:
    if num not in seen:
        result.append(num)
        seen.add(num)

print(result)

