Блок 3: Рекурсия и рекуррентные соотношения
 Задача 11. Числа Фибоначчи

1. Реализация
🔸 Наивная рекурсия O(2
n
)

def fib_recursive(n):
    if n <= 1:
        return n
    return fib_recursive(n - 1) + fib_recursive(n - 2)

Итеративный подход O(n)
def fib_iterative(n):
    a, b = 0, 1
    for _ in range(n):
        a, b = b, a + b
    return a

2. Замер времени
import time

def measure(func, n):
    start = time.perf_counter()
    result = func(n)
    end = time.perf_counter()
    return result, end - start


for n in range(10, 45, 5):
    print(f"\nn = {n}")

    _, t_iter = measure(fib_iterative, n)
    print(f"Итеративный: {t_iter:.6f} сек")

    _, t_rec = measure(fib_recursive, n)
    print(f"Рекурсивный: {t_rec:.6f} сек")

