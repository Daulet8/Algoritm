Блок 1: Эмпирический анализ
🔹 Линейный vs Бинарный поиск
def linear_search(arr, target):
    for i in range(len(arr)):
        if arr[i] == target:
            return i
    return -1


def binary_search(arr, target):
    left, right = 0, len(arr) - 1

    while left <= right:
        mid = (left + right) // 2

        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            left = mid + 1
        else:
            right = mid - 1

    return -1

2. Замер времени
import time
import random
import matplotlib.pyplot as plt

sizes = [100, 1000, 10000, 100000, 500000, 1000000]

linear_times = []
binary_times = []

for n in sizes:
    arr = list(range(n))  # отсортированный массив
    target = random.choice(arr)

    # Линейный поиск
    start = time.time()
    linear_search(arr, target)
    end = time.time()
    linear_times.append(end - start)

    # Бинарный поиск
    start = time.time()
    binary_search(arr, target)
    end = time.time()
    binary_times.append(end - start)

    print(f"n={n} готово")

3. Построение графика
plt.figure(figsize=(10, 6))

plt.plot(sizes, linear_times, label="Линейный поиск", marker='o')
plt.plot(sizes, binary_times, label="Бинарный поиск", marker='o')

plt.xlabel("Размер массива (n)")
plt.ylabel("Время (секунды)")
plt.title("Сравнение линейного и бинарного поиска")

plt.legend()
plt.grid()

plt.show()

Что ты увидишь на графике
Линейный поиск → растёт линейно O(n)
Бинарный поиск → почти плоская линия O(log n)

 При n = 1 000 000:

линейный поиск становится заметно медленным
бинарный почти не меняется 

Важные замечания
Бинарный поиск работает только на отсортированном массиве
Для честного теста:
используй одинаковые данные
можно запускать несколько раз и брать среднее
time.time() можно заменить на более точный:


time.perf_counter()

def measure_time(func, arr, target, repeats=5):
    total = 0
    for _ in range(repeats):
        start = time.perf_counter()
        func(arr, target)
        end = time.perf_counter()
        total += (end - start)
    return total / repeats

Вывод (для отчёта)
Линейный поиск имеет сложность O(n)
Бинарный поиск имеет сложность O(log n)
На больших данных бинарный поиск в десятки и сотни раз быстрее
Эмпирические результаты подтверждают теорию






